{
  "name": "maponomypoultry-server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc -w",
    "dev": "npx nodemon",
    "docker:dev": "docker compose --env-file .env.development -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "docker:prod": "docker compose --env-file .env.production -f docker-compose.yml -f docker-compose.prod.yml up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "drizzle:generate": "docker compose exec backend npx drizzle-kit generate --config ./src/config/drizzle.config.ts",
    "drizzle:migrate": "docker compose exec backend npx drizzle-kit migrate --config ./src/config/drizzle.config.ts",
    "drizzle:push": "docker compose exec backend npx drizzle-kit push --config ./src/config/drizzle.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.0",
    "@aws-sdk/client-s3": "^3.971.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "bcryptjs": "^3.0.3",
    "config": "^4.1.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "fastify": "^5.6.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "pg": "^8.16.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@types/config": "^3.3.5",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
